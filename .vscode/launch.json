{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Client (Debug)",
            "type": "coreclr",
            "request": "launch",
            "program": "/home/antoineod/Documents/vintagestory/Vintagestory",
            "preLaunchTask": "build",
            "args": [
                "--tracelog",
                "--addModPath",
                "${workspaceFolder}/slidingwoodenshutters/bin/Debug/Mods",
                "--addOrigin",
                "${workspaceFolder}/slidingwoodenshutters/assets",
                "--logPath",
                "${workspaceFolder}/slidingwoodenshutters/bin/logs"
            ],
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "Launch Server",
            "type": "coreclr",
            "request": "launch",
            "program": "/home/antoineod/Documents/vintagestory/VintagestoryServer",
            "preLaunchTask": "build",
            "args": [
                "--tracelog",
                "--addModPath",
                "${workspaceFolder}/slidingwoodenshutters/bin/Debug/Mods",
                "--addOrigin",
                "${workspaceFolder}/slidingwoodenshutters/assets",
                "--logPath",
                "${workspaceFolder}/slidingwoodenshutters/bin/logs"
            ],
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "Cake Build (Package Mod)",
            "type": "coreclr",
            "request": "launch",
            "program": "dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/ZZCakeBuild/CakeBuild.csproj",
                "--configuration",
                "Release",
                "--",
                "--target=Default"
            ],
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false
        }
    ]
}